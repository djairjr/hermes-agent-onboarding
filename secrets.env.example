# Copy this file to ~/.hermes/secrets.env and fill in your real keys.
# 
# WARNING: Never commit the real secrets.env to git.
# Only this .example file should be in version control.

# ============================================================
# LLM PROVIDER
# ============================================================
# OpenRouter (recommended — one API key for many models)
# OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# OpenAI
# OPENAI_API_KEY="sk-your-key-here"

# Anthropic
# ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ============================================================
# SUPABASE — Core Infrastructure
# ============================================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key"

# Supabase Personal Access Token (for CLI operations)
SUPABASE_PAT="sbp_your-personal-access-token"

# ============================================================
# MCP KEYS — Each Edge Function has its own key
# ============================================================
# Generate with: openssl rand -hex 32
FINANCE_MCP_KEY="your-64-hex-char-key"
WORK_OPERATING_MODEL_MCP_KEY="your-64-hex-char-key"

# Add more as you deploy more Edge Functions:
# TECH_KB_MCP_KEY="..."
# CRM_MCP_KEY="..."
# etc.

# ============================================================
# DEFAULT USER (single-user mode)
# ============================================================
# For single-user setups, set this to a user_profiles.id UUID
# The finance MCP server scopes all operations to this user.
DEFAULT_USER_ID="00000000-0000-0000-0000-000000000000"

# ============================================================
# OPTIONAL — Home Assistant, Telegram, etc.
# ============================================================
# HASS_TOKEN="..."
# TELEGRAM_BOT_TOKEN="..."
